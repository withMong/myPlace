{
  "uid": "line9-delay",
  "title": "서울 9호선 지연 분석 (배치)",
  "tags": ["seoul-metro", "line9", "delay", "batch"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "연착 빈번 역 Top5",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT station_nm AS 역, arrivals AS 도착, delayed AS 지연, ROUND(delay_rate*100,1) AS `지연율(%)`, avg_delay_sec AS 평균지연초 FROM subway.v_delay_top_station ORDER BY delayed DESC, delay_rate DESC LIMIT 5;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "시간대별 지연율 — 평일 (%)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "continuous-RdYlGr" } }, "overrides": [] },
      "options": { "orientation": "vertical", "xField": "time_band", "showValue": "auto", "legend": { "showLegend": false } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT time_band, ROUND(delay_rate*100,1) AS delay_rate_pct FROM subway.v_delay_by_timeband WHERE day_type='평일' ORDER BY CASE time_band WHEN '새벽' THEN 1 WHEN '출근' THEN 2 WHEN '점심' THEN 3 WHEN '퇴근' THEN 4 ELSE 5 END;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "시간대별 평균 지연(초) — 평일",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "orientation": "vertical", "xField": "time_band", "showValue": "auto", "legend": { "showLegend": false } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT time_band, avg_delay_sec FROM subway.v_delay_by_timeband WHERE day_type='평일' ORDER BY CASE time_band WHEN '새벽' THEN 1 WHEN '출근' THEN 2 WHEN '점심' THEN 3 WHEN '퇴근' THEN 4 ELSE 5 END;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "시간대 × 요일유형 지연 집계",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT day_type AS 요일, time_band AS 시간대, arrivals AS 도착, delayed AS 지연, ROUND(delay_rate*100,1) AS `지연율(%)`, avg_delay_sec AS 평균지연초 FROM subway.v_delay_by_timeband ORDER BY 요일, CASE time_band WHEN '새벽' THEN 1 WHEN '출근' THEN 2 WHEN '점심' THEN 3 WHEN '퇴근' THEN 4 ELSE 5 END;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    }
  ]
}
