{
  "uid": "line9-realtime",
  "title": "서울 9호선 실시간 운행 현황",
  "tags": ["seoul-metro", "line9", "realtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "운행 중 열차",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT active_trains FROM v_live_summary;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "상행",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT up_trains FROM v_live_summary;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "하행",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT down_trains FROM v_live_summary;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "급행",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT express_trains FROM v_live_summary;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "급행 vs 일반",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT CASE WHEN is_express = 1 THEN '급행' ELSE '일반' END AS train_type, COUNT(*) AS trains FROM v_train_latest GROUP BY is_express;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "역별 이벤트 Top 10",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "continuous-BlPu" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xField": "statn_nm", "showValue": "auto", "legend": { "showLegend": false } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT statn_nm, event_cnt FROM v_station_traffic ORDER BY event_cnt DESC LIMIT 10;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "현재 열차 위치",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 12 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT train_no AS 열차, direction AS 방향, statn_nm AS 현재역, dest_nm AS 행선, status_nm AS 상태, recptn_ts AS 수신시각 FROM v_train_latest ORDER BY direction, statn_nm;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "시간대별 이벤트 추이",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 12 },
      "datasource": { "type": "mysql", "uid": "starrocks" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "orientation": "vertical", "xField": "hour_bucket", "showValue": "auto", "legend": { "showLegend": false } },
      "targets": [ { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT hour_bucket, event_cnt FROM v_hourly_trend ORDER BY hour_bucket;", "datasource": { "type": "mysql", "uid": "starrocks" } } ]
    }
  ]
}
